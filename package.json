{
  "name": "scrapa",
  "version": "0.2.6",
  "description": "Scrape Parse Transform Repeat",
  "main": "./src/scrapa.js",
  "type": "module",
  "engines": {
    "node": ">= 20.0.0"
  },
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "coverage": "node --experimental-vm-modules node_modules/.bin/jest --collect-coverage",
    "postinstall": "node tasks/postinstall.js || exit 0",
    "lint": "eslint src/** tests/**"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LandRover/scrapa.git"
  },
  "keywords": [],
  "author": "Oleg Glozman <git@landroverz.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/LandRover/scrapa/issues"
  },
  "homepage": "https://github.com/LandRover/scrapa#readme",
  "dependencies": {
    "cheerio": "^1.2.0",
    "fast-xml-parser": "^5.5.9",
    "https-proxy-agent": "^8.0.0",
    "json-2-csv": "^5.5.10",
    "node-fetch": "^3.3.2",
    "puppeteer": "^24.40.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "random-useragent": "^0.5.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "babel-jest": "^30.3.0",
    "eslint": "^10.1.0",
    "jest": "^30.3.0",
    "nock": "^14.0.11",
    "ts-jest": "^29.4.6"
  },
  "jest": {
    "testTimeout": 60000,
    "preset": "ts-jest",
    "testEnvironment": "node",
    "transform": {
      "^.+\\.(js)$": "babel-jest"
    },
    "moduleDirectories": [
      "<rootDir>/src",
      "node_modules"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/tests/fixtures/"
    ],
    "moduleFileExtensions": [
      "js"
    ],
    "verbose": false
  }
}